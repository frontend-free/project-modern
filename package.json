{
  "name": "project-modern",
  "version": "1.0.0",
  "private": true,
  "description": "## 选型",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "copy-dot-cursor": "node scripts/copy-dot-cursor.js",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "build-api": "pnpm --filter @lib/api build-api",
    "build-code": "pnpm --filter @lib/api build-code",
    "clean": "rm -rf pnpm-lock.yaml node_modules **/*/node_modules dist",
    "build-docker": "docker build -t project-modern .",
    "build:agent": "pnpm --filter ./apps/agent build",
    "dev:agent": "pnpm --filter ./apps/agent dev",
    "build": "pnpm build:agent",
    "dev": "pnpm dev:agent"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-router-dom": "catalog:",
    "ahooks": "catalog:",
    "dotenv-expand": "catalog:",
    "husky": "catalog:",
    "i18next-cli": "catalog:",
    "lint-staged": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">= 24.14.0",
    "pnpm": ">= 10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "patchedDependencies": {
      "@ant-design/pro-components@3.1.6-0": "patches/@ant-design__pro-components@3.1.6-0.patch"
    }
  }
}
