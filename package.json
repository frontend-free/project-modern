{
  "name": "project-modern",
  "version": "1.0.0",
  "private": true,
  "description": "## 选型",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky install",
    "preinstall": "npx only-allow pnpm",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "build-api": "pnpm --filter @lib/api build-api",
    "build-code": "pnpm --filter @lib/api build-code",
    "clean": "rm -rf pnpm-lock.yaml node_modules **/*/node_modules dist",
    "build:agent": "pnpm --filter ./apps/agent build",
    "dev:agent": "pnpm --filter ./apps/agent dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.0",
    "@fe-free/commit-lint": "^7.0.1",
    "@fe-free/style-lint": "^7.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.8.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-router-dom": "^5.3.3",
    "ahooks": "3.8.4",
    "dotenv-expand": "^11.0.6",
    "husky": "^8.0.3",
    "i18next-cli": "^1.34.1",
    "lint-staged": "^15.2.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.15.0",
    "stylelint": "^16.6.1",
    "typescript": "5.3.2"
  },
  "engines": {
    "node": ">= 22.14.0",
    "pnpm": ">= 10.18.2"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "patchedDependencies": {
      "@ant-design/pro-components@3.1.6-0": "patches/@ant-design__pro-components@3.1.6-0.patch"
    }
  }
}
